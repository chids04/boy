[
  {
    "label": "cmake configure",
    "command": "cmake --preset debug",
  },
  {
    "label": "cmake build",
    "command": "cmake --build --preset debug",
  },
  {
    "label": "run binary",
    "cwd": "$ZED_WORKTREE_ROOT",
    "command": "cmake --build --preset debug && ./build/debug/boy",
  },
  {
    "label": "run tests",
    "cwd": "$ZED_WORKTREE_ROOT",
    "command": "./test/gb_doctor/gameboy-doctor ./test/state.log cpu_instrs 2",
  },
]
